server port env PORT

database type sqlite

middleware cors
middleware logs

route GET /posts
  paginate post limit 10
  return posts

route POST /posts
  take title, body
  require title, body
  create post with title, body
  return post

route GET /posts/:id
  find post by id
  if not found return error "Post not found" status 404
  return post

route PUT /posts/:id
  take title, body
  update post with title, body
  return ok

route DELETE /posts/:id
  delete post by id
  return ok
